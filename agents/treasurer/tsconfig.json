{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "lib": ["es2022"],
    "types": ["node"]
  },
  "include": ["*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
