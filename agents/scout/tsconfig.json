{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "../../",
    "resolveJsonModule": true,
    "moduleResolution": "node"
  },
  "include": ["*.ts", "../../shared/*.ts"],
  "exclude": ["node_modules", "dist"]
}
