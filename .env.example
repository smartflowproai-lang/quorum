# QUORUM environment — copy to .env and fill in. Never commit .env.

# ─── AXL (Gensyn) ─────────────────────────────────────────────────────
# Peer bootstrap address: the other host's AXL node multiaddr.
# VPS-A (Frankfurt) sets AXL_PEER to VPS-B's multiaddr, and vice versa.
AXL_PEER=/ip4/0.0.0.0/tcp/4001/p2p/PeerIDHere
AXL_LISTEN_PORT=4001
AXL_NODE_NAME=scout-frankfurt    # or judge-frankfurt / executor-nyc / treasurer-nyc

# ─── Solana (Scout agent) ─────────────────────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=
# Watched smart-money wallets — JSON array of 14 addresses
SCOUT_WATCHED_WALLETS=["...","..."]

# ─── EVM (Scout bridge-linker, Judge graph-client) ────────────────────
BASE_RPC_URL=https://mainnet.base.org
ETH_RPC_URL=https://eth.llamarpc.com
WORMHOLE_API=https://api.wormholescan.io
DEBRIDGE_API=https://stats-api.dln.trade
ALLBRIDGE_API=https://core.api.allbridgecoreapi.net

# Read-only access to the EVM wallet graph (231K profiles)
WALLET_GRAPH_API=https://api.smartflowproai.com/wallet-graph/v1

# ─── KeeperHub (Executor agent) ───────────────────────────────────────
KEEPERHUB_API_URL=
KEEPERHUB_API_KEY=
KEEPERHUB_MCP_ENDPOINT=
KEEPERHUB_JITO_TIP_WEI=10000

# ─── 0G storage (shared) ──────────────────────────────────────────────
OG_NODE_URL=
OG_INDEXER_URL=
OG_PRIVATE_KEY=   # wallet that pays 0G fees — separate from Treasurer

# ─── x402 (Treasurer agent) ───────────────────────────────────────────
X402_FACILITATOR_URL=https://facilitator.x402.org
TREASURER_USDC_WALLET_PATH=./treasurer/wallet/treasurer-keypair.json
TREASURER_MIN_BALANCE_USDC=5
TREASURER_MAX_PER_CALL_USDC=0.10

# ─── World Chain (Executor dual-write, conditional) ───────────────────
WORLD_CHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public
WORLD_CHAIN_FACILITATOR_URL=   # Coinbase x402 facilitator endpoint, live 2026-04-17
WORLD_DUAL_WRITE_ENABLED=false  # flipped true at Day-4 gate if partner prize confirmed

# ─── Attestation contracts ────────────────────────────────────────────
BASE_ATTESTATION_CONTRACT=      # filled after Day 5 deploy
WORLD_ATTESTATION_CONTRACT=     # filled after Day 6 deploy (conditional)

# ─── ERC-8004 registry (shared/erc8004-register.ts) ───────────────────
ERC8004_REGISTRY_BASE=          # ERC-8004 canonical registry on Base
ERC8004_REGISTRATION_KEY=       # funded wallet, Day 7 task, ~$30 gas budget

# ─── Telegram alerts (status pings) ───────────────────────────────────
TG_BOT_TOKEN=
TG_CHAT_ID=

# ─── MCP server (Executor exposes quorum/submit-verdict) ──────────────
MCP_SERVER_PORT=3001
MCP_ALLOWED_ORIGINS=   # comma-separated list of caller agent IDs or "*" for open

# ─── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
LOG_JSON=true    # structured logs for grep + 0G archival

# ─── Build metadata (filled by CI) ────────────────────────────────────
GIT_SHA=
BUILD_TIME=
